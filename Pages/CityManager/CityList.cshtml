@page
@model DR4_TP2.Pages.CityManager.CityListModel
@{
    ViewData["Title"] = "Exercício 9";
}

<h1>Exercício 9 — Lista de Cidades</h1>
<p><a href="/">← Voltar ao Menu</a></p>

<ul class="lista">
    @foreach (var city in Model.Cities)
    {
        <li>
            @city —
            <a asp-page="/CityManager/CityDetails" asp-route-cityName="@city">Ver Detalhes</a>
        </li>
    }
</ul>

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 20px;
    }

    h1 {
        margin-bottom: 10px;
    }

    .lista {
        padding-left: 20px;
        line-height: 2;
    }

    a {
        color: #0077cc;
    }
</style>