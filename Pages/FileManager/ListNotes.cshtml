@page
@model DR4_TP2.Pages.FileManager.ListNotesModel
@{
    ViewData["Title"] = "Exercício 11";
}

<h1>Exercício 11 — Listar Notas</h1>
<p><a href="/">← Voltar ao Menu</a> | <a asp-page="/FileManager/SaveNote">+ Nova Nota</a></p>

@if (!Model.Files.Any())
{
    <p>Nenhum arquivo encontrado.</p>
}
else
{
    <ul class="lista">
        @foreach (var file in Model.Files)
        {
            <li>
                <a asp-page="/FileManager/ListNotes" asp-route-file="@file">@file</a>
            </li>
        }
    </ul>
}

@if (!string.IsNullOrEmpty(Model.SelectedFile))
{
    <h2>@Model.SelectedFile</h2>
    <pre class="conteudo">@Model.FileContent</pre>
    <p><a href="/files/@Model.SelectedFile" target="_blank">Download</a></p>
}

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 20px;
    }

    h1, h2 {
        margin-bottom: 10px;
    }

    .lista {
        padding-left: 20px;
        line-height: 2;
    }

    .conteudo {
        background: #f5f5f5;
        border: 1px solid #ccc;
        padding: 10px;
        max-width: 600px;
        white-space: pre-wrap;
        font-family: Arial, sans-serif;
        font-size: 14px;
    }

    a {
        color: #0077cc;
    }
</style>
