@page
@model DR4_TP2.Pages.IndexModel
@{
    ViewData["Title"] = "Teste de Performance - TP2 DR4";
}

<h1>Menu de Exercícios</h1>

<div class="menu">
    <ul>
        @foreach (var ex in Model.Exercises)
        {
            <li>
                <a asp-page="@ex.Page">Exercício @ex.Number - @ex.Title</a>
            </li>
        }
    </ul>
</div>

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 20px;
    }

    h1 {
        text-align: center;
        margin-bottom: 30px;
    }

    .menu ul {
        list-style-type: none;
        padding: 0;
        max-width: 600px;
        margin: 0 auto;
    }

    .menu li {
        border: 1px solid #ccc;
        padding: 10px;
        margin-bottom: 10px;
        text-align: center;
    }

    .menu a {
        text-decoration: none;
        font-weight: bold;
        color: #0077cc;
    }

        .menu a:hover {
            text-decoration: underline;
        }
</style>

